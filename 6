using System;

namespace Task6_WordCount
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Title = "Задание 6. Количество слов";
            
            Console.Write("Введите предложение: ");
            string input = Console.ReadLine();
            
            string[] words = input.Split(new char[] { ' ', '\t', '\n' }, StringSplitOptions.RemoveEmptyEntries);
            
            Console.WriteLine($"Количество слов: {words.Length}");
            
            Console.WriteLine("\nСлова по отдельности:");
            for (int i = 0; i < words.Length; i++)
            {
                Console.WriteLine($"{i + 1}. {words[i]}");
            }
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
